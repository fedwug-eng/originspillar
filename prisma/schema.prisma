generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  stripeCustomerId String?
  website          String?
  industry         String?
  companySize      String?
  address          String?
  logoUrl          String?
  brandColorPrimary   String?   @default("#7c3aed")
  brandColorSecondary String?   @default("#4338ca")
  plan             String    @default("starter")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  users         User[]
  services      Service[]
  clients       Client[]
  requests      Request[]
  subscriptions Subscription[]
  comments      Comment[]
  conversations Conversation[]
  messages      Message[]
  activityLogs  ActivityLog[]
  apiKeys       ApiKey[]
  
  // API Gateway Relations
  providerCredentials ProviderCredential[]
  gatewayKeys     GatewayKey[]
  usageRecords    UsageRecord[]
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  firstName   String?
  lastName    String?
  clerkUserId String?  @unique
  role        Role     @default(MEMBER)
  phone       String?
  bio         String?
  jobTitle    String?
  location    String?
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  comments       Comment[]
  sentMessages   Message[]      @relation("MessageSender")
  activityLogs   ActivityLog[]  @relation("ActivityActor")
}

model Client {
  id               String   @id @default(cuid())
  name             String
  slug             String?
  contactName      String?
  email            String
  phone            String?
  website          String?
  location         String?
  notes            String?
  status           String   @default("Active")
  plan             String?
  stripeCustomerId String?  @unique
  workspaceId      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requests      Request[]
  subscriptions Subscription[]
  conversations Conversation[]
}

model Service {
  id              String   @id @default(cuid())
  name            String
  description     String?
  price           Decimal  @db.Decimal(10, 2)
  status          String   @default("Active") // Active, Draft, Archived
  type            String   @default("One-Off") // Recurring, One-Off
  icon            String?
  deliverables    Json?    // JSON array of strings
  stripeProductId String?
  stripePriceId   String?
  workspaceId     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requests    Request[]
}

model Request {
  id          String    @id @default(cuid())
  title       String
  slug        String?
  description String?
  status      String    @default("Backlog") // Backlog, In Progress, In Review, Completed
  progress    Int       @default(0)
  budget      Decimal?  @db.Decimal(10, 2)
  dueDate     DateTime?
  tag         String?
  clientId    String
  serviceId   String?
  workspaceId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client      Client    @relation(fields: [clientId], references: [id])
  service     Service?  @relation(fields: [serviceId], references: [id])
  comments    Comment[]
  conversations Conversation[]
}

enum Role {
  ADMIN
  MANAGER
  MEMBER
  CLIENT
}

model Subscription {
  id                   String   @id @default(cuid())
  stripeSubscriptionId String   @unique
  status               String // active, canceled, past_due
  amount               Int      @default(0)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)

  clientId    String?
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client    Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Comment {
  id          String   @id @default(cuid())
  text        String
  requestId   String
  authorId    String
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  request   Request   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── New Models ───────────────────────────────────────────

model ActivityLog {
  id           String   @id @default(cuid())
  actorId      String
  action       String   // e.g. "request.created", "invoice.paid", "client.onboarded"
  resourceType String   // e.g. "request", "client", "invoice", "service"
  resourceId   String
  metadata     Json?    // Extra context: { amount, oldStatus, newStatus, etc. }
  workspaceId  String
  readAt       DateTime?
  createdAt    DateTime @default(now())

  actor     User      @relation("ActivityActor", fields: [actorId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Conversation {
  id                 String    @id @default(cuid())
  clientId           String
  requestId          String?   // null = general client chat
  lastMessageAt      DateTime  @default(now())
  lastMessagePreview String?
  workspaceId        String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  request   Request?  @relation(fields: [requestId], references: [id], onDelete: SetNull)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([clientId, requestId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  senderType     String    @default("agency") // "agency" or "client"
  body           String
  readAt         DateTime?
  workspaceId    String
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id])
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id          String   @id @default(cuid())
  name        String   // e.g. "Zapier Integration", "Stripe Live Key"
  keyType     String   @default("external") // "external" (agency-owned) or "platform" (Originspillar-generated)
  keyHash     String   // For platform keys: bcrypt hash. For external: encrypted value
  keyPrefix   String   // First 8 chars for display (e.g. "op_live_a" or "sk_live_")
  status      String   @default("active") // "active" or "revoked"
  lastUsedAt  DateTime?
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── API Gateway Models ────────────────────────────────────────

model ProviderCredential {
  id            String   @id @default(cuid())
  provider      String   // openai, anthropic, deepseek, or custom name
  providerType  String   @default("builtin") // builtin or custom
  keyName       String   // User-friendly name
  encryptedKey  String   // Encrypted API key
  keyPreview    String   // Last 4 chars for display
  
  endpointUrl   String?  // Custom API endpoint URL
  models        String?  // JSON array of available models: ["model-1", "model-2"]
  apiFormat     String   @default("openai") // openai, anthropic
  
  isActive      Boolean  @default(true)
  lastUsedAt    DateTime?
  
  workspaceId   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model GatewayKey {
  id                  String   @id @default(cuid())
  keyPrefix           String   // For lookup: "af_abc123xx" (first 10 chars)
  keyName             String   // User-friendly: "Production Key"
  keyHash             String   // Hash - NEVER decryptable
  
  rateLimitRpm        Int      @default(60)
  rateLimitRpd        Int      @default(10000)
  maxTokensPerRequest Int      @default(128000)
  
  status              String   @default("active") // active, expired, revoked
  lastUsedAt          DateTime?
  expiresAt           DateTime?
  
  workspaceId         String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  usageRecords        UsageRecord[]

  @@unique([workspaceId, keyPrefix])
  @@index([keyPrefix])
}

model UsageRecord {
  id              String   @id @default(cuid())
  endpoint        String   // /chat, /embeddings, etc.
  model           String   // gpt-4, claude-3-opus, etc.
  provider        String   // openai, anthropic, deepseek
  
  promptTokens    Int      @default(0)
  completionTokens Int     @default(0)
  totalTokens     Int      @default(0)
  
  providerCost    Float    @default(0) // What provider charges company
  markupApplied   Float    @default(0) // Company's markup amount
  agencyCost      Float    @default(0) // Total charged by agency
  
  latency         Int      @default(0) // Response time in ms
  statusCode      Int      @default(200)
  errorMessage    String?
  ipAddress       String?
  userAgent       String?
  
  gatewayKeyId    String?
  workspaceId     String
  createdAt       DateTime @default(now())
  
  gatewayKey      GatewayKey? @relation(fields: [gatewayKeyId], references: [id], onDelete: SetNull)
  workspace       Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  @@index([workspaceId, createdAt])
  @@index([workspaceId, provider])
}

model PricingOracle {
  id              String   @id @default(cuid())
  model           String   @unique
  provider        String
  promptCostPerM  Float    // Cost per 1M prompt tokens in USD
  completionCostPerM Float // Cost per 1M completion tokens in USD
  updatedAt       DateTime @updatedAt
}
